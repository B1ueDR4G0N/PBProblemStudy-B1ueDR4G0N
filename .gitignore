# Original normalized PB benchmark corpus
/normalized-PB24/

# Standalone normalized PB benchmark files in the repository root
/normalized-*.opb*

# External benchmark OPB files are not redistributed.
/problems/**/*.opb
!/problems/sample/
!/problems/sample/*.opb

# Local Gurobi credentials and Python environment
gurobi.lic
/GUROBI/.venv/

# Python cache
__pycache__/
*.py[cod]

# Solver run artifacts
*.watcher.log
*.var
/solver.log
/watcher.log
/result.var
/results/gurobi_scip/*/

# Build products and local installations
/SCIP/build/
/SCIP/local/
/SCIP/vendor/*-build/
/runsolver/src/runsolver
/runsolver/src/*.o
/runsolver/src/*.d
/naps/naps-1.02b

# Local dependency headers/libraries used while trying Open-WBO
/OpenWBO/
/OpenWBO/local/

# External solver source/build trees kept locally
/RoundingSat/

# Curated representative logs kept for reports
!/LOG/
!/LOG/**

# Windows alternate data stream metadata accidentally created on download
*:Zone.Identifier
